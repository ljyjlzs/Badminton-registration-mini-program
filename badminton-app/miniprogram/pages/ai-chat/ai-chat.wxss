/* pages/ai-chat/ai-chat.wxss */
.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f5f5f5;
}

/* ============ 顶部栏 ============ */
.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  padding-top: calc(20rpx + env(safe-area-inset-top));
  background: #ffffff;
  border-bottom: 1rpx solid #eeeeee;
}

.top-bar-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.new-chat-btn {
  padding: 10rpx 28rpx;
  font-size: 24rpx;
  color: #07c160;
  border: 1rpx solid #07c160;
  border-radius: 30rpx;
}

/* ============ 空状态 ============ */
.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 60rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  text-align: center;
  line-height: 1.6;
}

/* ============ 消息列表 ============ */
.msg-list {
  flex: 1;
  height: 0;  /* 必须设 0 让 flex 子元素可滚动 */
  padding: 24rpx 24rpx 16rpx;
  box-sizing: border-box;
}

.loading-tip {
  text-align: center;
  color: #999;
  font-size: 24rpx;
  padding: 20rpx 0;
}

/* ============ 消息行 ============ */
.msg-row {
  display: flex;
  flex-direction: column;
  margin-bottom: 24rpx;
}

.msg-right {
  align-items: flex-end;
}

.msg-left {
  align-items: flex-start;
}

/* ============ 气泡 ============ */
.msg-bubble {
  max-width: 70%;
  padding: 20rpx 28rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  line-height: 1.6;
  word-break: break-all;
}

.bubble-user {
  background: linear-gradient(135deg, #07c160, #06a84e);
  color: #fff;
  border-bottom-right-radius: 6rpx;
}

.bubble-ai {
  background: #ffffff;
  color: #333;
  border-bottom-left-radius: 6rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.msg-text {
  user-select: text;
}

.msg-time {
  font-size: 20rpx;
  color: #bbbbbb;
  margin-top: 6rpx;
}

/* ============ 底部输入栏 ============ */
.input-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx calc(16rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-top: 1rpx solid #eeeeee;
  gap: 16rpx;
}

.msg-input {
  flex: 1;
  height: 72rpx;
  padding: 0 24rpx;
  background: #f5f5f5;
  border-radius: 36rpx;
  font-size: 28rpx;
  color: #333;
}

.send-btn {
  min-width: 120rpx;
  height: 72rpx;
  line-height: 72rpx;
  background: linear-gradient(135deg, #07c160, #06a84e);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 36rpx;
  border: none;
  padding: 0 24rpx;
}

.send-btn.disabled {
  background: #cccccc;
}
