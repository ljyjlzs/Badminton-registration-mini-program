.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #667eea 0%, #764ba2 100%);
  padding-bottom: 40rpx;
}

.header {
  text-align: center;
  padding: 60rpx 40rpx 40rpx;
  color: #fff;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 28rpx;
  opacity: 0.8;
}

.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  color: #fff;
}

.content {
  padding: 20rpx;
}

.section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.team-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.qualified-team {
  background-color: #e8f5e9;
  border-radius: 12rpx;
  padding: 20rpx;
}

.team-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #388e3c;
  margin-bottom: 8rpx;
}

.team-members {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.team-score {
  font-size: 24rpx;
  color: #07c160;
}

.empty-tip {
  text-align: center;
  color: #999;
  padding: 40rpx 0;
}

.player-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.player-card {
  width: 150rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  background-color: #fff3e0;
  border-radius: 12rpx;
}

.player-card:active {
  background-color: #ffe0b2;
}

.player-card .avatar,
.player-card .avatar-text,
.player-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  background-color: #ff9800;
  overflow: hidden;
}

.player-avatar image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.player-card .nickname {
  font-size: 26rpx;
  color: #333;
  text-align: center;
  max-width: 130rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.player-card .level {
  font-size: 22rpx;
  color: #ff9800;
}

.challenge-ready {
  background: linear-gradient(135deg, #fff9c4 0%, #fff59d 100%);
}

.match-card {
  padding: 30rpx;
  background-color: #fff;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.match-teams {
  display: flex;
  justify-content: space-around;
  align-items: center;
}

.match-teams .team {
  text-align: center;
}

.match-teams .team-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.match-teams .team-members {
  font-size: 24rpx;
  color: #666;
}

.vs {
  font-size: 48rpx;
  font-weight: bold;
  color: #ff9800;
}

.btn-start {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background-color: #ff9800;
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 48rpx;
  border: none;
}
