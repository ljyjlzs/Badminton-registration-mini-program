/* ============ 容器与布局 ============ */
.container {
  min-height: 100vh;
  background-color: var(--bg-gray);
  padding: var(--spacing-md);
  box-sizing: border-box;
}

.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  color: var(--text-tertiary);
  font-size: 28rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--border-color);
  border-top-color: var(--primary-color);
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.content {
  padding: var(--spacing-md);
}

/* ============ 活动卡片 ============ */
.activity-card {
  background-color: var(--bg-white);
  border-radius: var(--radius-md);
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-md);
  box-shadow: var(--shadow-md);
  border: 1rpx solid var(--border-light);
}

.activity-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: var(--spacing-md);
  padding-bottom: var(--spacing-md);
  border-bottom: 1rpx solid var(--border-color);
}

.activity-name {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  flex: 1;
  margin-right: var(--spacing-sm);
  line-height: 1.4;
}

.activity-status {
  font-size: 22rpx;
  padding: 8rpx 20rpx;
  border-radius: var(--radius-full);
  font-weight: 600;
  white-space: nowrap;
}

.status-registering {
  background: linear-gradient(135deg, #e8f8f3 0%, #d4efdf 100%);
  color: #00a06b;
  border: 1rpx solid #b8e0c8;
}

.status-grouping {
  background: linear-gradient(135deg, #fff8e6 0%, #ffecb3 100%);
  color: #f57c00;
  border: 1rpx solid #ffe0b2;
}

.status-playing {
  background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);
  color: #1976d2;
  border: 1rpx solid #90caf9;
}

.status-finished {
  background: linear-gradient(135deg, #f5f5f5 0%, #eeeeee 100%);
  color: #9e9e9e;
  border: 1rpx solid #e0e0e0;
}

/* ============ 信息行 ============ */
.activity-info-row {
  display: flex;
  align-items: center;
  margin-bottom: var(--spacing-sm);
  padding: 12rpx 0;
}

.activity-info-row:last-child {
  margin-bottom: 0;
}

.info-icon {
  margin-right: var(--spacing-sm);
  font-size: 32rpx;
  width: 48rpx;
  text-align: center;
  color: var(--primary-color);
}

.info-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  flex: 1;
  line-height: 1.5;
}

.info-label {
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-right: 8rpx;
}

/* ============ 进度条 ============ */
.progress-section {
  margin-top: var(--spacing-md);
  padding-top: var(--spacing-md);
  border-top: 1rpx solid var(--border-color);
}

.progress-bar {
  height: 12rpx;
  background-color: var(--bg-gray);
  border-radius: var(--radius-full);
  overflow: hidden;
  margin-bottom: 12rpx;
}

.progress-fill {
  height: 100%;
  background: var(--primary-gradient);
  border-radius: var(--radius-full);
  transition: width 0.3s ease;
}

.progress-text {
  font-size: 24rpx;
  color: var(--text-secondary);
  text-align: center;
}

/* ============ 提示信息 ============ */
.organizer-tip {
  margin-top: var(--spacing-md);
  padding: var(--spacing-sm) var(--spacing-md);
  background: linear-gradient(135deg, #fff8e6 0%, #ffecb3 100%);
  border-radius: var(--radius-sm);
  font-size: 24rpx;
  color: #f57c00;
  text-align: center;
  border: 1rpx solid #ffe0b2;
}

/* ============ 通用区块 ============ */
.section {
  background-color: var(--bg-white);
  border-radius: var(--radius-md);
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-md);
  box-shadow: var(--shadow-md);
  border: 1rpx solid var(--border-light);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacing-md);
  padding-bottom: var(--spacing-sm);
  border-bottom: 1rpx solid var(--border-color);
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  position: relative;
  padding-left: var(--spacing-md);
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 32rpx;
  background: var(--primary-gradient);
  border-radius: 3rpx;
}

.section-count {
  font-size: 24rpx;
  color: var(--text-tertiary);
  background-color: var(--bg-gray);
  padding: 6rpx 16rpx;
  border-radius: var(--radius-full);
}

/* ============ 报名列表 ============ */
.registration-list {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacing-md);
  padding: var(--spacing-sm) 0;
}

.registration-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 140rpx;
  padding: var(--spacing-sm);
  background-color: var(--bg-gray);
  border-radius: var(--radius-sm);
  transition: all 0.2s ease;
}

.registration-item:active {
  transform: scale(0.95);
  background-color: var(--border-color);
}

.registration-item .avatar,
.registration-item .avatar-text {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  background: var(--primary-gradient);
  box-shadow: 0 4rpx 12rpx rgba(0, 176, 126, 0.3);
  flex-shrink: 0;
}

.registration-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  margin-bottom: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 176, 126, 0.3);
  flex-shrink: 0;
}

.registration-avatar image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.registration-item .nickname {
  font-size: 24rpx;
  color: var(--text-primary);
  text-align: center;
  max-width: 140rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-weight: 500;
}

/* ============ 等级徽章 ============ */
.level-badge {
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: var(--radius-full);
  font-size: 20rpx;
  font-weight: 600;
  color: #fff;
  margin-top: 8rpx;
}

.level-1, .level-2, .level-3 {
  background: linear-gradient(135deg, #81c784 0%, #66bb6a 100%);
}

.level-4, .level-5, .level-6 {
  background: linear-gradient(135deg, #ffb74d 0%, #ffa726 100%);
}

.level-7, .level-8, .level-9, .level-10 {
  background: linear-gradient(135deg, #e57373 0%, #ef5350 100%);
}

/* ============ 空状态 ============ */
.empty-tip {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: var(--text-tertiary);
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: var(--spacing-md);
  opacity: 0.5;
}

/* ============ 操作按钮区 ============ */
.action-section {
  margin-top: var(--spacing-lg);
}

.btn-primary {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: var(--primary-gradient);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: var(--radius-lg);
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(0, 176, 126, 0.35);
  transition: all 0.2s ease;
}

.btn-primary:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(0, 176, 126, 0.25);
}

.btn-primary.disabled {
  background: #cccccc;
  box-shadow: none;
}

.joined-tip {
  padding: var(--spacing-md);
  background: linear-gradient(135deg, #e8f8f3, #f1f8e9);
  border-radius: var(--radius-sm);
  color: var(--primary-color);
  font-size: 28rpx;
  text-align: center;
  border: 1rpx solid #c8e6c9;
}

.full-tip {
  padding: var(--spacing-md);
  background-color: var(--bg-gray);
  border-radius: var(--radius-sm);
  color: var(--text-tertiary);
  font-size: 28rpx;
  text-align: center;
}

/* ============  organizer 操作 ============ */
.organizer-action {
  margin-top: var(--spacing-md);
}

.btn-center {
  display: flex;
  justify-content: center;
}

.btn-center .btn-start {
  width: auto;
  padding: 0 60rpx;
}

.btn-challenge {
  width: auto;
  padding: 0 60rpx;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #e91e63, #f06292);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: var(--radius-lg);
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(233, 30, 99, 0.35);
}

.btn-final {
  width: auto;
  padding: 0 60rpx;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #ff9800, #ffc107);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: var(--radius-lg);
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(255, 152, 0, 0.35);
}

.section-tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: var(--radius-full);
  font-weight: 600;
}

.challenge-tag {
  background: linear-gradient(135deg, #e91e63, #f06292);
  color: #fff;
}

.final-match {
  background: linear-gradient(135deg, #ff9800, #ffc107) !important;
}

.challenge-match {
  background: linear-gradient(135deg, #e91e63, #f06292) !important;
}

.playing-status {
  background: rgba(255, 255, 255, 0.3) !important;
  color: #fff !important;
}

.confirm-status {
  background: rgba(255, 152, 0, 0.8) !important;
  color: #fff !important;
}

/* 比赛状态样式 - 优先级最高 */
.match-pending {
  background: linear-gradient(135deg, #78909c 0%, #546e7a 100%) !important;
  border: 2rpx dashed rgba(255,255,255,0.5) !important;
}

.match-playing, 
.challenge-match.match-playing, 
.final-match.match-playing {
  background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%) !important;
  animation: pulse 1.5s ease-in-out infinite !important;
  border: 2rpx solid rgba(255,255,255,0.8) !important;
}

.match-confirming,
.challenge-match.match-confirming,
.final-match.match-confirming {
  background: linear-gradient(135deg, #f57c00 0%, #ff9800 100%) !important;
  animation: blink 1s ease-in-out infinite !important;
}

.match-confirmed,
.challenge-match.match-confirmed,
.final-match.match-confirmed {
  background: linear-gradient(135deg, #636e72 0%, #b2bec3 100%) !important;
  opacity: 0.85 !important;
}

@keyframes pulse {
  0%, 100% { 
    box-shadow: 0 8rpx 24rpx rgba(56, 239, 125, 0.4);
  }
  50% { 
    box-shadow: 0 8rpx 40rpx rgba(56, 239, 125, 0.7);
  }
}

@keyframes blink {
  0%, 100% { 
    box-shadow: 0 8rpx 24rpx rgba(255, 152, 0, 0.4);
    transform: scale(1);
  }
  50% { 
    box-shadow: 0 8rpx 32rpx rgba(255, 152, 0, 0.7);
    transform: scale(1.02);
  }
}

.start-hint {
  padding: var(--spacing-sm) var(--spacing-md);
  background: linear-gradient(135deg, #e8f8f3, #c8e6c9);
  border-radius: var(--radius-sm);
  color: var(--primary-color);
  font-size: 28rpx;
  margin-bottom: var(--spacing-md);
  text-align: center;
  border: 1rpx solid #a5d6a7;
}

.wait-hint {
  padding: var(--spacing-sm) var(--spacing-md);
  background: linear-gradient(135deg, #fff3e0, #ffecb3);
  border-radius: var(--radius-sm);
  color: #f57c00;
  font-size: 28rpx;
  margin-bottom: var(--spacing-md);
  text-align: center;
  border: 1rpx solid #ffcc80;
}

.btn-start {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #ff9800, #ffb74d);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: var(--radius-lg);
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(255, 152, 0, 0.35);
}

.organizer-btns {
  display: flex;
  gap: var(--spacing-md);
  flex-wrap: wrap;
}

.organizer-btns .btn-start,
.organizer-btns .btn-delete,
.organizer-btns .btn-finish {
  flex: 1;
  min-width: 200rpx;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: var(--radius-lg);
  border: none;
  padding: 0 24rpx;
  white-space: nowrap;
  text-align: center;
}

.organizer-btns .btn-start {
  background: linear-gradient(135deg, #ff9800, #ffb74d);
  box-shadow: 0 6rpx 20rpx rgba(255, 152, 0, 0.3);
  color: #fff;
}

.organizer-btns .btn-delete {
  background: var(--bg-white);
  color: #f44336;
  border: 2rpx solid #f44336;
  box-shadow: none;
}

.organizer-btns .btn-finish {
  background: linear-gradient(135deg, #667eea, #764ba2);
  box-shadow: 0 6rpx 20rpx rgba(102, 126, 234, 0.3);
  color: #fff;
}

/* ============ 比赛列表 ============ */
.match-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-md);
}

.match-card {
  background-color: var(--bg-white);
  border-radius: var(--radius-lg);
  padding: var(--spacing-lg);
  box-shadow: var(--shadow-lg);
  border: 1rpx solid var(--border-light);
}

/* ============ 场地卡片 ============ */
.venue-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: var(--radius-lg);
  padding: var(--spacing-lg);
  color: #fff;
  box-shadow: var(--shadow-lg);
}

.venue-title {
  font-size: 34rpx;
  font-weight: 700;
  text-align: center;
  margin-bottom: var(--spacing-md);
  letter-spacing: 4rpx;
}

.team-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--spacing-sm) var(--spacing-md);
  background-color: rgba(255, 255, 255, 0.15);
  border-radius: var(--radius-sm);
  margin-bottom: 12rpx;
  backdrop-filter: blur(10rpx);
}

.team-name {
  font-size: 28rpx;
  font-weight: 700;
}

.team-members {
  font-size: 24rpx;
  opacity: 0.9;
}

.vs-divider {
  text-align: center;
  font-size: 56rpx;
  font-weight: 800;
  padding: var(--spacing-sm) 0;
  color: rgba(255, 255, 255, 0.8);
  letter-spacing: 8rpx;
}

.match-score {
  text-align: center;
  font-size: 56rpx;
  font-weight: 700;
  padding: var(--spacing-md);
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: var(--radius-sm);
  letter-spacing: 2rpx;
}

.match-status {
  text-align: center;
  font-size: 26rpx;
  opacity: 0.85;
  padding: var(--spacing-sm);
  background-color: rgba(255, 255, 255, 0.1);
  border-radius: var(--radius-sm);
  margin-top: var(--spacing-sm);
}

.btn-ranking {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: var(--radius-lg);
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.35);
}

/* ============ 选择器弹窗 ============ */
.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: var(--bg-overlay);
  display: flex;
  align-items: flex-end;
  z-index: 1000;
  backdrop-filter: blur(4rpx);
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.picker-content {
  width: 100%;
  background-color: var(--bg-white);
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  padding: 40rpx var(--spacing-md) calc(40rpx + env(safe-area-inset-bottom));
  animation: slideUp 0.3s ease;
}

.picker-title {
  font-size: 34rpx;
  font-weight: 700;
  text-align: center;
  margin-bottom: 40rpx;
  color: var(--text-primary);
}

.level-picker {
  height: 400rpx;
}

.level-option {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  padding: var(--spacing-md) 0;
  transition: background-color 0.2s ease;
}

.level-option:active {
   background-color: var(--bg-gray);
 }

/* 新增：点击式等级选择器样式 */
.level-selector {
   display: flex;
   flex-wrap: wrap;
   gap: 16rpx;
   margin-top: 20rpx;
 }

.level-item {
   flex: 1 1 calc(33.333% - 16rpx);
   min-width: 80rpx;
   padding: 16rpx 12rpx;
   background-color: var(--bg-gray);
   border: 2rpx solid var(--border-color);
   border-radius: var(--radius-md);
   text-align: center;
   font-size: 28rpx;
   color: var(--text-secondary);
   transition: all 0.2s ease;
   box-sizing: border-box;
 }

.level-item.selected {
   background: var(--primary-gradient);
   color: #fff;
   border-color: transparent;
   transform: translateY(-2rpx);
   box-shadow: 0 4rpx 12rpx rgba(0, 176, 126, 0.3);
 }

.level-item:active {
   background-color: var(--bg-gray);
   transform: scale(0.95);
 }

.picker-actions {
  display: flex;
  gap: var(--spacing-md);
  margin-top: 40rpx;
}

.btn-cancel, .btn-confirm {
  flex: 1;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: var(--radius-lg);
  font-size: 30rpx;
  font-weight: 600;
  border: none;
}

.btn-cancel {
  background-color: var(--bg-gray);
  color: var(--text-secondary);
}

.btn-confirm {
  background: var(--primary-gradient);
  color: #fff;
  box-shadow: 0 6rpx 20rpx rgba(0, 176, 126, 0.3);
}

/* ============ 表单项 ============ */
.picker-content .form-item {
  margin-bottom: var(--spacing-md);
}

.picker-content .form-label {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: var(--spacing-sm);
  font-weight: 500;
  display: block;
}

.picker-content .form-input {
  height: 88rpx;
  line-height: 88rpx;
  padding: 0 var(--spacing-md);
  border: 2rpx solid var(--border-color);
  border-radius: var(--radius-sm);
  font-size: 30rpx;
  background-color: var(--bg-gray);
  transition: all 0.2s ease;
}

.picker-content .form-input:focus {
  border-color: var(--primary-color);
  background-color: var(--bg-white);
  box-shadow: 0 0 0 4rpx rgba(0, 176, 126, 0.1);
}

.avatar-form-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-form-item .avatar-preview {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
}

.avatar-change-hint {
  font-size: 22rpx;
  color: var(--primary-color);
  margin-top: 8rpx;
}

/* 搭档选择 */
.partner-tag {
  font-size: 20rpx;
  color: var(--primary-color);
}

.reg-info {
  display: flex;
  flex-direction: column;
}

.partner-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 8rpx 0;
}

.partner-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 20rpx;
  border-radius: 32rpx;
  background: var(--bg-gray);
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.partner-item.selected {
  border-color: var(--primary-color);
  background: rgba(0, 176, 126, 0.08);
}

.partner-avatar {
  width: 48rpx;
  height: 48rpx;
  min-width: 48rpx;
  font-size: 22rpx;
  border-radius: 50%;
}

.partner-name {
  font-size: 26rpx;
  color: var(--text-primary);
}

.partner-level {
  font-size: 20rpx;
  color: #999;
}

.avatar-upload-area {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 2rpx dashed var(--border-color);
  background-color: var(--bg-gray);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-preview {
  width: 100%;
  height: 100%;
}

.avatar-upload-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
