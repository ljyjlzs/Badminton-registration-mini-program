/* 创建活动页面样式 */

.container {
  padding: 24rpx;
  background-color: var(--bg-gray);
  min-height: 100vh;
}

.form-section {
  background-color: var(--bg-white);
  border-radius: var(--radius-md);
  padding: 36rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm);
  border: 1rpx solid var(--border-light);
}

.form-title {
  font-size: 36rpx;
  font-weight: 800;
  color: var(--text-primary);
  margin-bottom: 36rpx;
  text-align: center;
  letter-spacing: 4rpx;
}

.form-item {
  margin-bottom: 36rpx;
}

.form-label {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
  display: block;
}

.form-input {
  height: 96rpx;
  background-color: var(--bg-gray);
  border-radius: var(--radius-sm);
  padding: 0 28rpx;
  font-size: 30rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
  color: var(--text-primary);
}

.form-input:focus {
  border-color: var(--primary-color);
  background-color: var(--bg-white);
}

.form-input::placeholder {
  color: var(--text-light);
}

/* 活动类型切换 */
.type-toggle {
  display: flex;
  gap: 24rpx;
}

.type-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background-color: var(--bg-gray);
  border-radius: var(--radius-sm);
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-secondary);
  border: 2rpx solid var(--border-light);
  transition: all 0.3s ease;
}

.type-btn.active {
  background: var(--primary-light);
  color: var(--primary-color);
  border-color: var(--primary-color);
  box-shadow: 0 4rpx 16rpx rgba(0, 176, 126, 0.15);
}

/* 地点选择行 */
.location-row {
  display: flex;
  gap: 20rpx;
  align-items: center;
}

.location-input {
  flex: 1;
}

.btn-select-location {
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  background: var(--primary-gradient);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  padding: 0 36rpx;
  border-radius: var(--radius-sm);
  white-space: nowrap;
  box-shadow: 0 4rpx 16rpx rgba(0, 176, 126, 0.2);
}

/* 选择器值 */
.picker-value {
  height: 96rpx;
  line-height: 96rpx;
  background-color: var(--bg-gray);
  border-radius: var(--radius-sm);
  padding: 0 60rpx 0 28rpx;
  font-size: 30rpx;
  color: var(--text-primary);
  display: flex;
  align-items: center;
  position: relative;
}

.picker-value::after {
  content: '▼';
  position: absolute;
  right: 28rpx;
  font-size: 20rpx;
  color: var(--text-light);
}

/* 人数信息 */
.player-info {
  display: flex;
  justify-content: space-between;
  font-size: 26rpx;
  color: var(--text-tertiary);
  background-color: var(--bg-gray);
  padding: 24rpx;
  border-radius: var(--radius-sm);
  font-weight: 500;
}

/* 提示区域 */
.tip-section {
  background-color: var(--bg-white);
  border-radius: var(--radius-md);
  padding: 36rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm);
  border: 1rpx solid var(--border-light);
}

.tip-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 20rpx;
}

.tip-item {
  font-size: 26rpx;
  color: var(--text-tertiary);
  line-height: 1.8;
  padding-left: 16rpx;
  position: relative;
}

.tip-item::before {
  content: '•';
  position: absolute;
  left: 0;
  color: var(--primary-color);
}

/* 提交按钮容器 */
.btn-submit-container {
  padding: 24rpx;
}

/* 提交按钮 */
.btn-submit {
  width: 100%;
  height: 100rpx;
  line-height: 100rpx;
  background: var(--primary-gradient);
  color: #fff;
  font-size: 34rpx;
  font-weight: 700;
  border-radius: var(--radius-xl);
  border: none;
  box-shadow: 0 8rpx 32rpx rgba(0, 176, 126, 0.3);
  letter-spacing: 4rpx;
}

.btn-submit[disabled] {
  background: #cccccc;
  box-shadow: none;
}