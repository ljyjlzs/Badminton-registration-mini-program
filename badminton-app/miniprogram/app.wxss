/* 全局样式 - 专业运动风格 */
page {
  background-color: #f8f9fa;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', 'Segoe UI', Roboto, 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
  color: #1a1a1a;
  
  /* 主色调 */
  --primary-color: #00b07e;
  --primary-dark: #008c61;
  --primary-light: #e8f8f3;
  --primary-gradient: linear-gradient(135deg, #00b07e 0%, #00c48c 100%);
  
  /* 文字颜色 */
  --text-primary: #1a1a1a;
  --text-secondary: #5c5c5c;
  --text-tertiary: #8c8c8c;
  --text-light: #b3b3b3;
  
  /* 背景色 */
  --bg-white: #ffffff;
  --bg-gray: #f5f5f5;
  --bg-light: #fafafa;
  --bg-overlay: rgba(0, 0, 0, 0.5);
  
  /* 边框 */
  --border-color: #e6e6e6;
  --border-light: #f0f0f0;
  
  /* 阴影 */
  --shadow-sm: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  --shadow-md: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  --shadow-lg: 0 8rpx 32rpx rgba(0, 0, 0, 0.12);
  --shadow-card: 0 2rpx 12rpx rgba(0, 176, 126, 0.08);
  
  /* 圆角 */
  --radius-xs: 8rpx;
  --radius-sm: 12rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-xl: 32rpx;
  --radius-full: 9999rpx;
  
  /* 间距 */
  --spacing-xs: 8rpx;
  --spacing-sm: 16rpx;
  --spacing-md: 24rpx;
  --spacing-lg: 32rpx;
  --spacing-xl: 48rpx;
}

/* 容器 */
.container {
  padding: 32rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 背景渐变 */
.bg-gradient {
  background: var(--primary-gradient);
}

/* ============ 按钮样式 ============ */

/* 主按钮 */
.btn-primary {
  background: var(--primary-gradient);
  color: #ffffff;
  border-radius: var(--radius-lg);
  padding: 24rpx 48rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(0, 176, 126, 0.3);
  transition: all 0.3s ease;
}

.btn-primary:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.btn-primary[disabled] {
  background: #cccccc;
  box-shadow: none;
}

/* 次按钮 */
.btn-secondary {
  background: var(--bg-white);
  color: var(--primary-color);
  border-radius: var(--radius-lg);
  padding: 24rpx 48rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 500;
  border: 2rpx solid var(--primary-color);
}

.btn-secondary:active {
  background: var(--primary-light);
}

/* 文字按钮 */
.btn-text {
  background: transparent;
  color: var(--primary-color);
  padding: 16rpx 24rpx;
  font-size: 28rpx;
  border: none;
}

/* 圆形按钮 */
.btn-circle {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--primary-light);
  color: var(--primary-color);
}

/* ============ 卡片样式 ============ */

.card {
  background: var(--bg-white);
  border-radius: var(--radius-md);
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm);
  border: 1rpx solid var(--border-light);
}

/* 浮动卡片 */
.card-float {
  background: var(--bg-white);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  box-shadow: var(--shadow-md);
}

/* 渐变卡片 */
.card-gradient {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  color: #ffffff;
}

/* ============ 页面标题 ============ */

.page-header {
  padding: 40rpx 32rpx;
  background: var(--primary-gradient);
  color: #ffffff;
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.page-subtitle {
  font-size: 26rpx;
  opacity: 0.9;
  margin-top: 8rpx;
}

/* ============ 等级徽章 ============ */

.level-badge {
  display: inline-block;
  padding: 6rpx 20rpx;
  border-radius: var(--radius-full);
  font-size: 22rpx;
  font-weight: 600;
  color: #ffffff;
  background: var(--primary-color);
}

.level-1, .level-2, .level-3 { 
  background: linear-gradient(135deg, #81c784 0%, #66bb6a 100%);
}

.level-4, .level-5, .level-6 { 
  background: linear-gradient(135deg, #ffb74d 0%, #ffa726 100%);
}

.level-7, .level-8, .level-9, .level-10 { 
  background: linear-gradient(135deg, #e57373 0%, #ef5350 100%);
}

/* ============ 场地卡片 ============ */

.venue-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  margin-bottom: 32rpx;
  color: #ffffff;
  box-shadow: var(--shadow-lg);
}

.venue-title {
  font-size: 34rpx;
  font-weight: 700;
  text-align: center;
  margin-bottom: 24rpx;
  letter-spacing: 4rpx;
}

.team-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: var(--radius-sm);
  margin-bottom: 12rpx;
  backdrop-filter: blur(10rpx);
}

.vs-divider {
  text-align: center;
  font-size: 56rpx;
  font-weight: 800;
  padding: 24rpx 0;
  letter-spacing: 8rpx;
}

/* ============ 状态徽章 ============ */

.status-badge {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 24rpx;
  border-radius: var(--radius-full);
  font-size: 24rpx;
  font-weight: 600;
}

.status-registering {
  background: linear-gradient(135deg, #e8f8f3 0%, #d4efdf 100%);
  color: #00a06b;
  border: 1rpx solid #b8e0c8;
}

.status-grouping {
  background: linear-gradient(135deg, #fff8e6 0%, #ffecb3 100%);
  color: #f57c00;
  border: 1rpx solid #ffe0b2;
}

.status-playing {
  background: linear-gradient(135deg, #e3f2fd 0%, #bbdefb 100%);
  color: #1976d2;
  border: 1rpx solid #90caf9;
}

.status-finished {
  background: linear-gradient(135deg, #f5f5f5 0%, #eeeeee 100%);
  color: #9e9e9e;
  border: 1rpx solid #e0e0e0;
}

/* ============ 表单样式 ============ */

.form-section {
  background: var(--bg-white);
  border-radius: var(--radius-md);
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm);
  border: 1rpx solid var(--border-light);
}

.form-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 32rpx;
  padding-bottom: 24rpx;
  border-bottom: 2rpx solid var(--border-light);
}

.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-secondary);
  margin-bottom: 16rpx;
  display: block;
}

.form-input {
  height: 96rpx;
  background: var(--bg-gray);
  border-radius: var(--radius-sm);
  padding: 0 28rpx;
  font-size: 30rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.form-input:focus {
  border-color: var(--primary-color);
  background: var(--bg-white);
  box-shadow: 0 0 0 4rpx rgba(0, 176, 126, 0.1);
}

.form-input::placeholder {
  color: var(--text-light);
}

/* ============ 加载状态 ============ */

.loading {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 80rpx 40rpx;
  color: var(--text-tertiary);
  font-size: 28rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--border-color);
  border-top: 4rpx solid var(--primary-color);
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* ============ 空状态 ============ */

.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  color: var(--text-tertiary);
  font-size: 28rpx;
}

.empty-tip .icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-tip text {
  margin-bottom: 16rpx;
}

/* ============ 列表项 ============ */

.list-item {
  background: var(--bg-white);
  border-radius: var(--radius-md);
  padding: 28rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-sm);
  border: 1rpx solid var(--border-light);
  transition: all 0.3s ease;
}

.list-item:active {
  background: var(--bg-gray);
}

/* ============ 分割线 ============ */

.divider {
  height: 1rpx;
  background: var(--border-color);
  margin: 24rpx 0;
}

.divider-dashed {
  height: 0;
  border-top: 1rpx dashed var(--border-color);
  margin: 24rpx 0;
}

/* ============ 头像 ============ */

.avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #e0e0e0 0%, #bdbdbd 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 600;
}

.avatar-lg {
  width: 120rpx;
  height: 120rpx;
  font-size: 48rpx;
}

.avatar-sm {
  width: 64rpx;
  height: 64rpx;
  font-size: 28rpx;
}

/* ============ 标签 ============ */

.tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 20rpx;
  border-radius: var(--radius-full);
  font-size: 24rpx;
  font-weight: 500;
}

.tag-primary {
  background: var(--primary-light);
  color: var(--primary-color);
}

.tag-gray {
  background: var(--bg-gray);
  color: var(--text-secondary);
}

/* ============ 动画 ============ */

.fade-in {
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.slide-up {
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from { 
    opacity: 0;
    transform: translateY(20rpx);
  }
  to { 
    opacity: 1;
    transform: translateY(0);
  }
}

/* ============ 工具类 ============ */

.text-primary { color: var(--text-primary); }
.text-secondary { color: var(--text-secondary); }
.text-tertiary { color: var(--text-tertiary); }
.text-light { color: var(--text-light); }
.text-primary-color { color: var(--primary-color); }

.text-sm { font-size: 24rpx; }
.text-md { font-size: 28rpx; }
.text-lg { font-size: 32rpx; }
.text-xl { font-size: 36rpx; }

.text-bold { font-weight: 700; }
.text-medium { font-weight: 500; }

.text-center { text-align: center; }
.text-left { text-align: left; }
.text-right { text-align: right; }

.mt-xs { margin-top: 8rpx; }
.mt-sm { margin-top: 16rpx; }
.mt-md { margin-top: 24rpx; }
.mt-lg { margin-top: 32rpx; }

.mb-xs { margin-bottom: 8rpx; }
.mb-sm { margin-bottom: 16rpx; }
.mb-md { margin-bottom: 24rpx; }
.mb-lg { margin-bottom: 32rpx; }

.flex { display: flex; }
.flex-center { display: flex; align-items: center; justify-content: center; }
.flex-between { display: flex; align-items: center; justify-content: space-between; }
.flex-column { display: flex; flex-direction: column; }